#!/bin/bash
# cmux setup hook — runs when `cmux new <branch>` creates a worktree.
# With claudecode.nvim + avante inside neovim, we don't need separate
# Claude or command panes. Just open the editor.
set -euo pipefail

if [[ -n "${TMUX:-}" ]]; then
  tmux rename-window "editor"
fi

echo "Worktree ready. Open neovim, then <leader>ac for Claude Code."
